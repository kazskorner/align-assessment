# ALIGN Assessment — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.
# Set all of these in Vercel: Settings → Environment Variables

# ── Neon PostgreSQL ───────────────────────────────────────────────────────────
# Get from: Neon dashboard → your project → Connection Details → Pooled connection
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_ENDPOINT.neon.tech/neondb?sslmode=require&channel_binding=require

# ── Wealthbox CRM ─────────────────────────────────────────────────────────────
# Get from: Wealthbox → Settings → API Access Token
WEALTHBOX_API_KEY=your_wealthbox_api_key_here

# ── Redtail CRM (optional — not yet wired) ───────────────────────────────────
REDTAIL_API_URL=https://api.redtail.com/v1
REDTAIL_API_KEY=your_redtail_api_key_here
REDTAIL_PARTNER_ID=your_partner_id_here

# ── App URLs ──────────────────────────────────────────────────────────────────
# Local development
NEXT_PUBLIC_API_URL=http://localhost:3000
# Production (set to your Vercel domain in Vercel dashboard, not here)
# NEXT_PUBLIC_API_URL=https://your-domain.com

# ── GitHub Actions (set as repo secrets in GitHub, not here) ─────────────────
# NEON_API_KEY        → GitHub repo → Settings → Secrets → Actions
# NEON_PROJECT_ID     → GitHub repo → Settings → Variables → Actions
